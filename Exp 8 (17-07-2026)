import pandas as pd

sales_data = pd.DataFrame({
    "Product":["Laptop","Mouse","Keyboard","Laptop","Mouse","Monitor","Printer","Laptop"],
    "Quantity":[10,20,15,5,12,18,9,7]
})

top_products = sales_data.groupby("Product")["Quantity"].sum().sort_values(ascending=False).head(5)

print("Top 5 Selling Products")
print(top_products)
